generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Un compte = un gérant de gîte
model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Période d'essai et abonnement
  planStatus   PlanStatus @default(TRIAL)
  trialEndsAt  DateTime?
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  // Tracking emails de rappel trial (évite les doublons)
  trialEmailSent15 Boolean @default(false)
  trialEmailSent5  Boolean @default(false)
  trialEmailSent1  Boolean @default(false)
  trialEmailSent0  Boolean @default(false)

  // Suppression automatique des comptes inactifs
  planExpiredAt       DateTime? // date à laquelle le compte est passé EXPIRED
  deletionWarningAt   DateTime? // date d'envoi de l'email d'avertissement J+30

  // Tier du plan souscrit — "essential" (1 gîte) ou "multi" (3 gîtes max)
  planTier  String @default("essential")

  // Type d'offre du compte — "gite" (location entière) ou "guesthouse" (maison
  // d'hôtes). Un compte est sur une seule offre, jamais les deux.
  offerType String @default("gite")

  gites       Gite[]
  guesthouses Guesthouse[]
}

// Maison d'hôtes — offre distincte du Gîte : location par chambre sur un même site.
// Limites légales : max 5 chambres, max 15 personnes. Taxe de séjour au réel.
model Guesthouse {
  id        String  @id @default(cuid())
  name      String
  // Slug public pour les URLs de réservation : kordia.fr/book/<slug>/<roomSlug>
  // Unique globalement (vérifié aussi contre Gite.slug pour éviter les collisions).
  slug      String? @unique
  address   String?
  city      String?
  zipCode   String?
  email     String?
  phone     String?

  // Plafond légal de personnes accueillies (max 15 pour une maison d'hôtes)
  capacity   Int   @default(15)
  // Taxe de séjour au réel : taux appliqué par adulte et par nuit
  touristTax Float @default(1.00)
  // Nombre max de couverts servis à la table d'hôtes par soir (0 = pas de limite)
  tableDhotesCapacity Int @default(0)
  // Acompte par défaut (en %) appliqué automatiquement au montant de l'hébergement
  // lors de la validation d'une demande de réservation. Le gérant peut surcharger
  // ponctuellement la valeur depuis le formulaire de validation.
  defaultDepositPercentage Float @default(30)
  // Coordonnées du médiateur de la consommation (article L.612-1 du Code de la
  // consommation). Obligatoire pour tout gérant professionnel (immatricule SIRET).
  // Si renseigne, l'article correspondant est automatiquement insere dans le contrat.
  mediatorInfo String?

  // Pipeline contrat partagé avec le Gîte
  contractTemplateGeneral    String?
  contractTemplateHouseRules String?
  logoUrl                    String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rooms        Room[]
  meals        GuesthouseMeal[]
  reservations Reservation[]
  documents    GuesthouseDocument[]
}

model GuesthouseDocument {
  id        String   @id @default(cuid())
  label     String
  fileName  String
  mimeType  String
  fileUrl   String
  createdAt DateTime @default(now())

  guesthouseId String
  guesthouse   Guesthouse @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)
}

// Menu / formule de restauration configurable par le gérant d'une maison d'hôtes
model GuesthouseMeal {
  id          String      @id @default(cuid())
  name        String                  // ex. "Petit-déjeuner continental", "Table d'hôtes"
  description String?                 // composition / détail du menu (gérant ET client)
  price       Float       @default(0)
  service     MealService @default(DINNER) // moment de service (agrégation cuisine)
  tags        String[]    @default([])      // ex. ["VEGETARIAN", "LOCAL"]
  active      Boolean     @default(true)
  position    Int         @default(0)
  createdAt   DateTime    @default(now())

  guesthouseId String
  guesthouse   Guesthouse @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)

  reservationMeals ReservationMeal[]
}

// Une chambre appartient à une maison d'hôtes
model Room {
  id        String  @id @default(cuid())
  name      String              // nom ou numéro de la chambre
  // Slug unique au sein d'une maison d'hôtes : kordia.fr/book/<guesthouseSlug>/<slug>
  slug      String?
  capacity  Int     @default(2) // capacité max en personnes
  basePrice   Float   @default(0) // prix de base par nuit
  cleaningFee Float   @default(0) // frais de ménage par séjour
  // Clauses contractuelles spécifiques à CETTE chambre, injectées dans le PDF
  // via la variable {{specificites_chambre}}. Optionnel, texte libre.
  specificClauses String?
  active    Boolean @default(true)
  position  Int     @default(0)

  createdAt DateTime @default(now())

  guesthouseId String
  guesthouse   Guesthouse @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)

  reservationRooms ReservationRoom[]
  icalFeeds        GuesthouseIcalFeed[]

  @@unique([guesthouseId, slug])
}

model GuesthouseIcalFeed {
  id           String    @id @default(cuid())
  platform     String
  label        String
  url          String
  syncedAt     DateTime?
  blockedDates Json      @default("[]")
  createdAt    DateTime  @default(now())

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

// Jointure réservation <-> chambre(s) avec snapshot au moment de la résa
model ReservationRoom {
  id       String @id @default(cuid())
  roomName String              // snapshot du nom de la chambre
  price    Float  @default(0)  // snapshot du prix nuitée

  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  roomId String?
  room   Room?  @relation(fields: [roomId], references: [id], onDelete: SetNull)
}

// Repas associés à une réservation (maison d'hôtes) — snapshot au moment de la résa
model ReservationMeal {
  id        String       @id @default(cuid())
  mealType  MealType
  service   MealService  @default(DINNER) // moment de service (agrégation cuisine)
  label     String              // ex. "Demi-pension" (snapshot)
  unitPrice Float        @default(0)
  quantity  Int          @default(1) // nombre de repas / jours

  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  guesthouseMealId String?
  guesthouseMeal   GuesthouseMeal? @relation(fields: [guesthouseMealId], references: [id], onDelete: SetNull)
}

// Un gîte appartient à un gérant
model Gite {
  id          String  @id @default(cuid())
  name        String
  address     String?
  city        String?
  zipCode     String?
  email       String?
  phone       String?
  capacity    Int     @default(12)
  cleaningFee Float   @default(90)
  touristTax  Float   @default(1.32)
  slug                  String? @unique
  contractTemplateGeneral    String?
  contractTemplateHouseRules String?
  logoUrl               String?  // Vercel Blob URL (formerly logoDataUrl base64)
  notificationEmail     String?
  notifNewReservation   Boolean @default(true)
  notifContractSigned   Boolean @default(true)
  notifPrysmNews        Boolean @default(false)
  driveTemplateFolderId String?
  driveOutputFolderId   String?
  n8nWebhookUrl         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime? // soft delete : le gîte ne compte plus mais ses archives sont conservées

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reservations Reservation[]
  options      GiteOption[]
  documents    GiteDocument[]
  icalFeeds    IcalFeed[]
}

model IcalFeed {
  id           String    @id @default(cuid())
  platform     String    // "airbnb" | "abritel" | "booking" | "leboncoin" | "gites_de_france" | "autre"
  label        String
  url          String
  syncedAt     DateTime?
  blockedDates Json      @default("[]") // [{start:"2026-05-01",end:"2026-05-10"}]
  createdAt    DateTime  @default(now())

  giteId String
  gite   Gite   @relation(fields: [giteId], references: [id], onDelete: Cascade)
}

// Options configurées par le gérant (dynamiques)
model GiteOption {
  id       String @id @default(cuid())
  label    String
  price    Float  @default(0)
  position Int    @default(0)

  giteId String
  gite   Gite   @relation(fields: [giteId], references: [id], onDelete: Cascade)

  reservationOptions ReservationOption[]
}

// Une réservation = un séjour client
model Reservation {
  id        String            @id @default(cuid())
  status    ReservationStatus @default(NEW)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Infos client
  clientFirstName String
  clientLastName  String
  clientEmail     String
  clientPhone     String
  clientAddress   String?
  clientCity      String?
  clientZipCode   String?

  // Dates du séjour
  checkIn  DateTime
  checkOut DateTime

  // Composition du séjour
  guestCount Int?
  // Nombre d'adultes — base de calcul de la taxe de séjour au réel (maison d'hôtes)
  adultsCount Int?
  // Notes alimentaires / allergies / régimes spécifiques des voyageurs
  dietaryNotes String?

  // Tarifs (null si demande client en attente de validation)
  rent        Float?
  deposit     Float?
  cleaningFee Float?
  touristTax  Float?

  notes String?

  refusalReason String?
  refusalNote   String?

  // Une réservation est rattachée SOIT à un Gîte SOIT à une Maison d'hôtes
  // (exactement un des deux — garanti côté API). giteId est nullable depuis
  // l'introduction des maisons d'hôtes ; les résas Gîte existantes le conservent.
  giteId String?
  gite   Gite?  @relation(fields: [giteId], references: [id], onDelete: Cascade)

  guesthouseId String?
  guesthouse   Guesthouse? @relation(fields: [guesthouseId], references: [id], onDelete: Cascade)

  contract            Contract?
  reservationOptions  ReservationOption[]
  reservationRooms    ReservationRoom[]
  meals               ReservationMeal[]
}

// Options sélectionnées pour une réservation (snapshot au moment de la résa)
model ReservationOption {
  id    String @id @default(cuid())
  label String
  price Float  @default(0)

  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  giteOptionId String?
  giteOption   GiteOption? @relation(fields: [giteOptionId], references: [id], onDelete: SetNull)
}

// Le contrat généré pour une réservation
model Contract {
  id        String         @id @default(cuid())
  status    ContractStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  driveFileId  String?
  driveFileUrl String?

  signatureToken          String?   @unique
  signatureTokenExpiresAt DateTime?
  signedAt                DateTime?
  signedByName   String?
  signedByIp     String?

  depositReceived   Boolean   @default(false)
  depositReceivedAt DateTime?
  signedPdfUrl      String?   // Vercel Blob URL of the signed PDF

  emailSentAt    DateTime?
  emailStatus    EmailStatus @default(NOT_SENT)
  reminderCount  Int         @default(0)
  lastReminderAt DateTime?

  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

// Documents joints aux emails (RIB, règlement intérieur, etc.)
model GiteDocument {
  id        String   @id @default(cuid())
  label     String
  fileName  String
  mimeType  String
  fileUrl   String   // Vercel Blob URL (formerly fileDataUrl base64)
  createdAt DateTime @default(now())

  giteId String
  gite   Gite   @relation(fields: [giteId], references: [id], onDelete: Cascade)
}

enum ReservationStatus {
  PENDING_REVIEW  // Demande client, en attente de validation par le gérant
  NEW             // Réservation confirmée / créée manuellement
  CONFIRMED
  CANCELLED
  REFUSED         // Refusée par le gérant (réversible)
}

enum ContractStatus {
  PENDING
  GENERATING
  GENERATED
  SIGNED
  ERROR
}

enum EmailStatus {
  NOT_SENT
  SENDING
  SENT
  ERROR
}

enum PlanStatus {
  TRIAL
  ACTIVE
  EXPIRED
}

enum MealType {
  BREAKFAST    // Petit-déjeuner
  HALF_BOARD   // Demi-pension
  TABLE_HOTES  // Table d'hôtes
}

enum MealService {
  BREAKFAST  // Petit-déjeuner
  LUNCH      // Déjeuner
  DINNER     // Dîner / table d'hôtes
  OTHER      // Autre
}
