generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Un compte = un gérant de gîte
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gites Gite[]
}

// Un gîte appartient à un gérant
model Gite {
  id          String  @id @default(cuid())
  name        String
  address     String?
  city        String?
  zipCode     String?
  email       String?
  phone       String?
  capacity    Int     @default(12)
  cleaningFee Float   @default(90)
  touristTax  Float   @default(1.32)
  slug                  String? @unique
  contractTemplate      String?
  logoUrl               String?
  notificationEmail     String?
  driveTemplateFolderId String?
  driveOutputFolderId   String?
  n8nWebhookUrl         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  reservations Reservation[]
  options      GiteOption[]
}

// Options configurées par le gérant (dynamiques)
model GiteOption {
  id       String @id @default(cuid())
  label    String
  price    Float  @default(0)
  position Int    @default(0)

  giteId String
  gite   Gite   @relation(fields: [giteId], references: [id], onDelete: Cascade)

  reservationOptions ReservationOption[]
}

// Une réservation = un séjour client
model Reservation {
  id        String            @id @default(cuid())
  status    ReservationStatus @default(NEW)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // Infos client
  clientFirstName String
  clientLastName  String
  clientEmail     String
  clientPhone     String
  clientAddress   String?
  clientCity      String?
  clientZipCode   String?

  // Dates du séjour
  checkIn  DateTime
  checkOut DateTime

  // Tarifs (null si demande client en attente de validation)
  rent        Float?
  deposit     Float?
  cleaningFee Float?
  touristTax  Float?

  notes String?

  giteId String
  gite   Gite   @relation(fields: [giteId], references: [id], onDelete: Cascade)

  contract            Contract?
  reservationOptions  ReservationOption[]
}

// Options sélectionnées pour une réservation (snapshot au moment de la résa)
model ReservationOption {
  id    String @id @default(cuid())
  label String
  price Float  @default(0)

  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  giteOptionId String?
  giteOption   GiteOption? @relation(fields: [giteOptionId], references: [id], onDelete: SetNull)
}

// Le contrat généré pour une réservation
model Contract {
  id        String         @id @default(cuid())
  status    ContractStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  driveFileId  String?
  driveFileUrl String?

  signatureToken String?   @unique
  signedAt       DateTime?
  signedByName   String?
  signedByIp     String?

  emailSentAt DateTime?
  emailStatus EmailStatus @default(NOT_SENT)

  depositReceived   Boolean   @default(false)
  depositReceivedAt DateTime?
  signedPdfUrl      String?

  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
}

enum ReservationStatus {
  PENDING_REVIEW  // Demande client, en attente de validation par le gérant
  NEW             // Réservation confirmée / créée manuellement
  CONFIRMED
  CANCELLED
}

enum ContractStatus {
  PENDING
  GENERATING
  GENERATED
  SIGNED
  ERROR
}

enum EmailStatus {
  NOT_SENT
  SENDING
  SENT
  ERROR
}
